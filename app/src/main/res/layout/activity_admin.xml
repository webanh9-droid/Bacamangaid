<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#111111">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🛠️ Admin Panel"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="20dp" />

        <!-- ===== PILIH MANGA ===== -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Pilih Manga"
            android:textColor="#4DB8FF"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <Spinner
            android:id="@+id/mangaSpinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp" />

        <!-- ===== SINOPSIS & GENRE ===== -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sinopsis &amp; Genre"
            android:textColor="#4DB8FF"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/synopsisInput"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:gravity="top|start"
            android:hint="Tulis sinopsis manga..."
            android:textColor="#FFFFFF"
            android:textColorHint="#888888"
            android:background="#222222"
            android:padding="10dp"
            android:inputType="textMultiLine" />

        <Spinner
            android:id="@+id/genreSpinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp" />

        <Button
            android:id="@+id/btnSaveMeta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:backgroundTint="#4DB8FF"
            android:text="Simpan Sinopsis &amp; Genre"
            android:textColor="#000000" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="20dp"
            android:background="#333333" />

        <!-- ===== UPLOAD CHAPTER ===== -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Upload Chapter Baru (PDF)"
            android:textColor="#4DB8FF"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/chapterNumberInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Nomor chapter"
            android:textColor="#FFFFFF"
            android:textColorHint="#888888"
            android:background="#222222"
            android:padding="10dp"
            android:inputType="number" />

        <Button
            android:id="@+id/btnPickPdf"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:backgroundTint="#444444"
            android:text="Pilih File PDF"
            android:textColor="#FFFFFF" />

        <TextView
            android:id="@+id/selectedPdfName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="#888888"
            android:text="Belum ada file dipilih" />

        <Button
            android:id="@+id/btnUploadPdf"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:backgroundTint="#4DB8FF"
            android:text="Upload Chapter"
            android:textColor="#000000" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="20dp"
            android:background="#333333" />

        <!-- ===== UPLOAD COVER ===== -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Upload / Ganti Cover"
            android:textColor="#4DB8FF"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <Button
            android:id="@+id/btnPickCover"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="#444444"
            android:text="Pilih Gambar Cover"
            android:textColor="#FFFFFF" />

        <TextView
            android:id="@+id/selectedCoverName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="#888888"
            android:text="Belum ada gambar dipilih" />

        <Button
            android:id="@+id/btnUploadCover"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:backgroundTint="#4DB8FF"
            android:text="Upload Cover"
            android:textColor="#000000" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="20dp"
            android:background="#333333" />

        <!-- ===== TAMBAH ADMIN ===== -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tambah Admin Baru"
            android:textColor="#4DB8FF"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:textColor="#888888"
            android:textSize="12sp"
            android:text="Orang itu harus udah pernah daftar/login di app dulu." />

        <EditText
            android:id="@+id/newAdminEmailInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Email calon admin baru"
            android:textColor="#FFFFFF"
            android:textColorHint="#888888"
            android:background="#222222"
            android:padding="10dp"
            android:inputType="textEmailAddress" />

        <Button
            android:id="@+id/btnAddAdmin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:backgroundTint="#CC3333"
            android:text="Jadikan Admin"
            android:textColor="#FFFFFF" />

    </LinearLayout>
</ScrollView>
